        "import pandas as pd\n",
        "import numpy as np\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "\n",
        "# 1. CELL-LEVEL DATA PRE-PROCESSING\n",
        "def load_cell_data(file_path):\n",
        "    with open(file_path, 'r') as f:\n",
        "        lines = f.readlines()\n",
        "    clean_lines = [line for line in lines[4:] if '/' in line.split(',')[0]]\n",
        "\n",
        "    with open('cell_cleaned.csv', 'w') as f:\n",
        "        f.writelines(lines[4:5])\n",
        "        f.writelines(clean_lines)\n",
        "\n",
        "    df = pd.read_csv('cell_cleaned.csv')\n",
        "    df['Time'] = pd.to_datetime(df['Time'])\n",
        "    return df\n",
        "\n",
        "# 2. SELECTIVE SSM MODEL (MAMBA CORE)\n",
        "class CellMambaSSM(nn.Module):\n",
        "    def __init__(self, d_model=1, d_state=4):\n",
        "        super(CellMambaSSM, self).__init__()\n",
        "        self.d_state = d_state\n",
        "        self.A_log = nn.Parameter(torch.log(torch.arange(1, d_state + 1).float()))\n",
        "        self.x_to_B = nn.Linear(d_model, d_state)\n",
        "        self.x_to_C = nn.Linear(d_model, d_state)\n",
        "        self.x_to_delta = nn.Linear(d_model, d_state)\n",
        "\n",
        "    def forward(self, x_seq):\n",
        "        h = torch.zeros(self.d_state)\n",
        "        outputs = []\n",
        "        A = -torch.exp(self.A_log)\n",
        "        for t in range(x_seq.size(0)):\n",
        "            x_t = x_seq[t]\n",
        "            delta = torch.sigmoid(self.x_to_delta(x_t))\n",
        "            B, C = self.x_to_B(x_t), self.x_to_C(x_t)\n",
        "            h = torch.exp(delta * A) * h + (delta * B) * x_t\n",
        "            outputs.append(torch.sum(h * C))\n",
        "        return torch.stack(outputs)\n",
        "\n",
        "# 3. PER-CELL OPTIMIZATION ENGINE\n",
        "def optimize_network_cells(df, forecast_hours=3):\n",
        "    unique_cells = df['Cell Name'].unique()\n",
        "    all_results = []\n",
        "\n",
        "    for cell in unique_cells:\n",
        "        cell_df = df[df['Cell Name'] == cell].sort_values('Time')\n",
        "        if len(cell_df) < 10: continue # Skip cells with insufficient data\n",
        "\n",
        "        # Prepare Data\n",
        "        data = cell_df['DL Traffic Volume (GB)'].values.astype(float)\n",
        "        mean, std = data.mean(), data.std()\n",
        "        if std == 0: std = 1\n",
        "        data_norm = (data - mean) / std\n",
        "\n",
        "        # Train Small SSM for the Cell\n",
        "        model = CellMambaSSM()\n",
        "        optimizer = optim.Adam(model.parameters(), lr=0.01)\n",
        "        inputs = torch.tensor(data_norm[:-1], dtype=torch.float32).unsqueeze(1)\n",
        "        targets = torch.tensor(data_norm[1:], dtype=torch.float32)\n",
        "\n",
        "        for _ in range(50): # Rapid training for edge deployment\n",
        "            optimizer.zero_grad()\n",
        "            loss = nn.MSELoss()(model(inputs), targets)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "\n",
        "        # Forecast\n",
        "        model.eval()\n",
        "        with torch.no_grad():\n",
        "            curr_x = inputs[-1]\n",
        "            preds_norm = []\n",
        "            h = torch.zeros(4) # Re-warm state\n",
        "            for t in range(len(inputs)):\n",
        "                delta = torch.sigmoid(model.x_to_delta(inputs[t]))\n",
        "                h = torch.exp(delta * (-torch.exp(model.A_log))) * h + (delta * model.x_to_B(inputs[t])) * inputs[t]\n",
        "\n",
        "            for _ in range(forecast_hours):\n",
        "                delta = torch.sigmoid(model.x_to_delta(curr_x))\n",
        "                h = torch.exp(delta * (-torch.exp(model.A_log))) * h + (delta * model.x_to_B(curr_x)) * curr_x\n",
        "                y_p = torch.sum(h * model.x_to_C(curr_x))\n",
        "                preds_norm.append(y_p.item())\n",
        "                curr_x = y_p.unsqueeze(0)\n",
        "\n",
        "        predictions = np.array(preds_norm) * std + mean\n",
        "\n",
        "        # Optimization Logic\n",
        "        t_high = cell_df['DL Traffic Volume (GB)'].quantile(0.9)\n",
        "        for i, pred in enumerate(predictions):\n",
        "            action = \"Expand Capacity\" if pred > t_high else \"Normal Operation\"\n",
        "            all_results.append({\n",
        "                'Cell Name': cell,\n",
        "                'Forecast_Hour': i + 1,\n",
        "                'Predicted_GB': round(pred, 4),\n",
        "                'Action': action\n",
        "            })\n",
        "\n",
        "    return pd.DataFrame(all_results)\n",
        "\n",
        "# EXECUTION\n",
        "df = load_cell_data('KPI Analysis Result_Query_Result_20260108140531703(KPI Analysis Result).csv')\n",
        "cell_plan = optimize_network_cells(df)\n",
        "print(cell_plan.head(15))\n",
        "cell_plan.to_csv('Cell_Level_Optimization_Plan.csv', index=False)"
