        "\n",
        "    # Plotting\n",
        "    plt.figure(figsize=(10, 5))\n",
        "    plt.plot(ts['Time'], ts['DL Traffic Volume (GB)'], label='Historical', color='gray')\n",
        "    plt.plot(results['Forecast_Time'], results['Predicted_Traffic_GB'], 'ro--', label='Mamba Forecast')\n",
