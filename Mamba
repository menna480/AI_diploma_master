        "import pandas as pd\n",
        "import numpy as np\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ==========================================\n",
        "# 1. DATA PRE-PROCESSING & CLEANING\n",
        "# ==========================================\n",
        "def load_and_clean_data(file_path):\n",
        "    with open(file_path, 'r') as f:\n",
        "        lines = f.readlines()\n",
        "\n",
        "    # Skip metadata (first 4 lines) and filter out footer/empty lines\n",
        "    # Valid data lines in this CSV start with a date (e.g., 1/1/2026)\n",
        "    clean_lines = [line for line in lines[4:] if '/' in line.split(',')[0]]\n",
        "\n",
        "    clean_file = 'cleaned_traffic_data.csv'\n",
        "    with open(clean_file, 'w') as f:\n",
        "        f.writelines(lines[4:5]) # Write the header\n",
        "        f.writelines(clean_lines) # Write valid data rows\n",
        "\n",
        "    df = pd.read_csv(clean_file)\n",
        "    df['Time'] = pd.to_datetime(df['Time'])\n",
        "\n",
        "    # Aggregate traffic across all cells to get network-level load\n",
        "    ts = df.groupby('Time')['DL Traffic Volume (GB)'].sum().reset_index().sort_values('Time')\n",
        "    return ts\n",
        "\n",
        "# ==========================================\n",
        "# 2. LAYER 1: SELECTIVE STATE-SPACE MODEL (MAMBA CORE)\n",
        "# ==========================================\n",
        "class MambaInspiredSSM(nn.Module):\n",
        "    \"\"\"\n",
        "    A simplified Selective State-Space Model.\n",
        "    Uses input-dependent (selective) parameters delta, B, and C.\n",
        "    \"\"\"\n",
        "    def __init__(self, d_model=1, d_state=8):\n",
        "        super(MambaInspiredSSM, self).__init__()\n",
        "        self.d_model = d_model\n",
        "        self.d_state = d_state\n",
        "\n",
        "        # Learnable parameter for the state transition matrix A\n",
        "        # Initialized as negative to ensure system stability\n",
        "        self.A_log = nn.Parameter(torch.log(torch.arange(1, d_state + 1).float()))\n",
        "\n",
        "        # Selective mechanisms (Linear projections based on current input x)\n",
        "        self.x_to_B = nn.Linear(d_model, d_state)\n",
        "        self.x_to_C = nn.Linear(d_model, d_state)\n",
        "        self.x_to_delta = nn.Linear(d_model, d_state)\n",
        "\n",
        "    def forward(self, x_seq):\n",
        "        seq_len = x_seq.size(0)\n",
        "        h = torch.zeros(self.d_state) # Hidden state\n",
        "        outputs = []\n",
        "        A = -torch.exp(self.A_log)\n",
        "\n",
        "        for t in range(seq_len):\n",
        "            x_t = x_seq[t]\n",
        "\n",
        "            # Selection Mechanism\n",
        "            delta = torch.sigmoid(self.x_to_delta(x_t))\n",
        "            B = self.x_to_B(x_t)\n",
        "            C = self.x_to_C(x_t)\n",
        "\n",
        "            # Discretization and Recurrence: h_t = A_bar * h_{t-1} + B_bar * x_t\n",
        "            A_bar = torch.exp(delta * A)\n",
        "            B_bar = delta * B\n",
        "            h = A_bar * h + B_bar * x_t\n",
        "\n",
        "            # Output projection: y_t = C * h_t\n",
        "            y_t = torch.sum(h * C)\n",
        "            outputs.append(y_t)\n",
        "\n",
        "        return torch.stack(outputs)\n",
        "\n",
        "# ==========================================\n",
        "# 3. TRAINING & FORECASTING ENGINE\n",
        "# ==========================================\n",
        "def train_and_forecast(ts_data, forecast_steps=5):\n",
        "    data = ts_data['DL Traffic Volume (GB)'].values.astype(float)\n",
        "    mean, std = data.mean(), data.std()\n",
        "    data_norm = (data - mean) / std\n",
        "\n",
        "    model = MambaInspiredSSM(d_model=1, d_state=8)\n",
        "    optimizer = optim.Adam(model.parameters(), lr=0.005)\n",
        "    criterion = nn.MSELoss()\n",
        "\n",
        "    # Prepare Tensors\n",
        "    inputs = torch.tensor(data_norm[:-1], dtype=torch.float32).unsqueeze(1)\n",
        "    targets = torch.tensor(data_norm[1:], dtype=torch.float32)\n",
        "\n",
        "    # Simple training loop\n",
        "    model.train()\n",
        "    for epoch in range(150):\n",
        "        optimizer.zero_grad()\n",
        "        preds = model(inputs)\n",
        "        loss = criterion(preds, targets)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "    # Forecasting\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        # Carry hidden state forward through historical data\n",
        "        h = torch.zeros(model.d_state)\n",
        "        A = -torch.exp(model.A_log)\n",
        "        for t in range(len(inputs)):\n",
        "            x_t = inputs[t]\n",
        "            delta = torch.sigmoid(model.x_to_delta(x_t))\n",
        "            B = model.x_to_B(x_t)\n",
        "            h = torch.exp(delta * A) * h + (delta * B) * x_t\n",
        "\n",
        "        # Predict future steps recursively\n",
        "        curr_x = inputs[-1]\n",
        "        preds_norm = []\n",
        "        for _ in range(forecast_steps):\n",
        "            delta = torch.sigmoid(model.x_to_delta(curr_x))\n",
        "            B = model.x_to_B(curr_x)\n",
        "            C = model.x_to_C(curr_x)\n",
        "            h = torch.exp(delta * A) * h + (delta * B) * curr_x\n",
        "            y_p = torch.sum(h * C)\n",
        "            preds_norm.append(y_p.item())\n",
        "            curr_x = y_p.unsqueeze(0)\n",
        "\n",
        "    predictions = np.array(preds_norm) * std + mean\n",
        "    return predictions\n",
        "\n",
        "# ==========================================\n",
        "# 4. LAYER 2: SELF-OPTIMIZATION LOGIC\n",
        "# ==========================================\n",
        "def execute_optimization(predictions, historical_data):\n",
        "    # Dynamic thresholds based on historical load distribution\n",
        "    t_high = historical_data.quantile(0.85)\n",
        "    t_low = historical_data.quantile(0.15)\n",
        "\n",
        "    actions = []\n",
        "    for val in predictions:\n",
        "        if val > t_high:\n",
        "            actions.append(\"CRITICAL LOAD: Expand PRB & Activate Aggregation\")\n",
        "        elif val < t_low:\n",
        "            actions.append(\"LOW LOAD: Activate Micro-Sleep Energy Saving\")\n",
        "        else:\n",
        "            actions.append(\"NORMAL LOAD: Maintain Dynamic Balancing\")\n",
        "    return actions, t_high, t_low\n",
        "\n",
        "# ==========================================\n",
        "# 5. MAIN EXECUTION\n",
        "# ==========================================\n",
        "if __name__ == \"__main__\":\n",
        "    CSV_FILE = 'KPI Analysis Result_Query_Result_20260108140531703(KPI Analysis Result).csv'\n",
        "\n",
        "    # Process Data\n",
        "    ts = load_and_clean_data(CSV_FILE)\n",
        "\n",
        "    # Run Mamba/SSM Prediction\n",
        "    forecasted_traffic = train_and_forecast(ts)\n",
        "\n",
        "    # Run Optimization Layer\n",
        "    actions, t_high, t_low = execute_optimization(forecasted_traffic, ts['DL Traffic Volume (GB)'])\n",
        "\n",
        "    # Generate Results Table\n",
        "    freq = ts['Time'].diff().iloc[-1]\n",
        "    future_times = [ts['Time'].iloc[-1] + (i + 1) * freq for i in range(len(forecasted_traffic))]\n",
        "\n",
        "    results = pd.DataFrame({\n",
        "        'Forecast_Time': future_times,\n",
        "        'Predicted_Traffic_GB': forecasted_traffic,\n",
        "        'Autonomous_Action': actions\n",
        "    })\n",
        "\n",
        "    print(\"\\n--- Network Self-Optimization Plan ---\")\n",
        "    print(results)\n",
        "\n",
        "    # Save results\n",
