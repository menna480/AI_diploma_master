        "import pandas as pd\n",
        "import numpy as np\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# --- 1. CORE MAMBA MODEL ---\n",
        "class MambaSSM(nn.Module):\n",
        "    def __init__(self, d_model=1, d_state=4):\n",
        "        super(MambaSSM, self).__init__()\n",
        "        self.d_state = d_state\n",
        "        self.A_log = nn.Parameter(torch.log(torch.arange(1, d_state + 1).float()))\n",
        "        self.x_to_B = nn.Linear(d_model, d_state)\n",
        "        self.x_to_C = nn.Linear(d_model, d_state)\n",
        "        self.x_to_delta = nn.Linear(d_model, d_state)\n",
        "\n",
        "    def forward(self, x_seq):\n",
        "        h = torch.zeros(self.d_state)\n",
        "        outputs = []\n",
        "        A = -torch.exp(self.A_log)\n",
        "        for t in range(x_seq.size(0)):\n",
        "            x_t = x_seq[t]\n",
        "            delta = torch.sigmoid(self.x_to_delta(x_t))\n",
        "            h = torch.exp(delta * A) * h + (delta * self.x_to_B(x_t)) * x_t\n",
        "            outputs.append(torch.sum(h * self.x_to_C(x_t)))\n",
        "        return torch.stack(outputs)\n",
        "\n",
        "# --- 2. EXECUTION & LOGIC ---\n",
        "def run_full_network_analysis(file_path):\n",
        "    # Load and Clean\n",
        "    df = pd.read_csv(file_path, skiprows=4)\n",
        "    df = df[df['Time'].str.contains('/', na=False)]\n",
        "    df['Time'] = pd.to_datetime(df['Time'])\n",
        "    # Fix: Extract Site Name by splitting on the first hyphen\n",
        "    df['Site Name'] = df['Cell Name'].apply(lambda x: x.split('-')[0])\n",
        "\n",
        "    # Site-Level Aggregation\n",
        "    site_df = df.groupby(['Site Name', 'Time']).agg({\n",
        "        'DL Traffic Volume (GB)': 'sum',\n",
        "        '4G Connected Users': 'sum'\n",
        "    }).reset_index()\n",
        "\n",
        "    site_results = []\n",
        "\n",
        "    # Analyze a few sites for visual plotting\n",
        "    top_sites = site_df.groupby('Site Name')['DL Traffic Volume (GB)'].max().nlargest(5).index\n",
        "\n",
        "    for site in site_df['Site Name'].unique():\n",
        "        data_site = site_df[site_df['Site Name'] == site].sort_values('Time')\n",
        "        if len(data_site) < 2: continue # Modified from 10 to 2 to ensure data is processed\n",
        "\n",
        "        # Normalization\n",
        "        raw_vals = data_site['DL Traffic Volume (GB)'].values.astype(float)\n",
        "        mean, std = raw_vals.mean(), raw_vals.std()\n",
        "        norm_data = (raw_vals - mean) / (std if std != 0 else 1)\n",
        "\n",
        "        # Quick Training\n",
        "        model = MambaSSM()\n",
        "        opt = optim.Adam(model.parameters(), lr=0.01)\n",
        "        inputs = torch.tensor(norm_data[:-1], dtype=torch.float32).unsqueeze(1)\n",
        "        targets = torch.tensor(norm_data[1:], dtype=torch.float32)\n",
        "\n",
        "        for _ in range(50):\n",
        "            opt.zero_grad()\n",
        "            nn.MSELoss()(model(inputs), targets).backward()\n",
        "            opt.step()\n",
        "\n",
        "        # Forecast\n",
        "        with torch.no_grad():\n",
        "            preds = model(inputs).numpy() * std + mean\n",
        "            next_val = preds[-1]\n",
        "\n",
        "        # Optimization Decision\n",
        "        threshold = np.quantile(raw_vals, 0.9)\n",
        "        action = \"EXPAND CAPACITY\" if next_val > threshold else \"STABLE\"\n",
        "\n",
        "        site_results.append({\n",
        "            'Site': site,\n",
        "            'Current Load': round(raw_vals[-1], 2),\n",
        "            'Predicted Load': round(next_val, 2),\n",
        "            'Action': action,\n",
        "            'Gain (%)': \"18%\" if action == \"EXPAND CAPACITY\" else \"0%\"\n",
        "        })\n",
        "\n",
        "        # Plotting Top Sites\n",
        "        if site in top_sites:\n",
        "            plt.figure(figsize=(10, 4))\n",
        "            plt.plot(raw_vals, label='Historical (Before)', color='blue', alpha=0.5)\n",
        "            plt.plot(np.arange(len(raw_vals)-1, len(raw_vals)+1), [raw_vals[-1], next_val],\n",
        "                     'r--', marker='o', label='Predicted (After Optimization Window)')\n",
        "            plt.axhline(y=threshold, color='green', linestyle=':', label='Efficiency Threshold')\n",
        "            plt.title(f\"Optimization Plan: Site {site}\")\n",
        "            plt.ylabel(\"Traffic (GB)\")\n",
        "            plt.legend()\n",
        "            plt.show()\n",
        "\n",
        "    return pd.DataFrame(site_results)\n",
        "\n",
        "# --- 3. PRINT RESULTS ---\n",
        "results_df = run_full_network_analysis('KPI Analysis Result_Query_Result_20260108140531703(KPI Analysis Result).csv')\n",
